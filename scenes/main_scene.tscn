[sub_resource type="GDScript" id="GDScript_4d01l"]
script/source = "extends RichTextLabel

@export var show_text_timer: float = 3.0
var clock: float = 0.0

func _process(delta: float) -> void:
	if visible:
		clock += delta
		visible_ratio = clock / show_text_timer
		if clock > show_text_timer:
			clock = 0.0
"

