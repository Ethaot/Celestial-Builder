[sub_resource type="GDScript" id="GDScript_almkq"]
script/source = "extends Button

@export var data_packs_menu_panel: DataPacksMenuPanel
@export var data_pack_file_dialog: FileDialog

func _ready() -> void:
	button_up.connect(_on_button_pressed)

func _on_button_pressed() -> void:
	if OS.has_feature(\"web\") or OS.has_feature(\"web_android\") or OS.has_feature(\"web_ios\"):
		data_packs_menu_panel.trigger_web_upload()
	else:
		data_pack_file_dialog.popup_file_dialog()


	
"

