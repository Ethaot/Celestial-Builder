[sub_resource type="GDScript" id="GDScript_ys0rt"]
script/source = "extends TextEdit

func _gui_input(event: InputEvent) -> void:
	if event is InputEventScreenTouch and event.is_pressed():
		grab_focus()
		DisplayServer.virtual_keyboard_show(text)
"

[sub_resource type="GDScript" id="GDScript_4d01l"]
script/source = "extends HBoxContainer

@export var shield_capacity_up_button: Button
@export var shield_capacity_down_button: Button
@export var shield_capacity_amount_label: Label

func _ready() -> void:
	shield_capacity_up_button.button_up.connect(_on_up_button_pressed)
	shield_capacity_down_button.button_up.connect(_on_down_button_pressed)

func _on_up_button_pressed() -> void:
	shield_capacity_amount_label.text = str(shield_capacity_amount_label.text.to_int() + 1)
	
func _on_down_button_pressed() -> void:
	shield_capacity_amount_label.text = str(shield_capacity_amount_label.text.to_int() - 1)
"

[sub_resource type="GDScript" id="GDScript_76g6l"]
script/source = "extends MobileFriendlyButton

@export var data_pack_selector_panel: DataPackSelectorPanel

func _ready() -> void:
	button_up.connect(_on_button_pressed)
	text = \"Current Data Pack: \" + DataManager.currently_edited_data_pack
	data_pack_selector_panel.new_data_pack_selected.connect(update_name)

func update_name(new_text: String) -> void:
	text = \"Current Data Pack: \" + new_text

func _on_button_pressed() -> void:
	data_pack_selector_panel.popup()
"

[sub_resource type="GDScript" id="GDScript_u23kh"]
script/source = "extends MobileFriendlyButton

func _ready() -> void:
	button_up.connect(_on_button_pressed)

func _on_button_pressed() -> void:
	ResourceManager.refresh_all_packs()
	await ResourceManager.packs_imported
	SceneManager.switch_scene(SceneManager.MAIN_SCENE)
"

[sub_resource type="GDScript" id="GDScript_6e685"]
script/source = "extends PanelContainer

@export var dropdown_button: Button
@export var dropdown_vbox: VBoxContainer

func _ready() -> void:
	dropdown_button.button_up.connect(popup)

func popup() -> void:
	size = Vector2(dropdown_button.size.x, dropdown_vbox.size.y)
	position = Vector2(dropdown_button.global_position.x, dropdown_button.global_position.y + dropdown_button.size.y + 8)
	visible = true
"

