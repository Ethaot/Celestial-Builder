; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="celestialbuilder"
config/version="0.1.0"
run/main_scene="uid://d2twsscusvcdc"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

Constants="*uid://cg7t8sxtwujfr"
DataManager="*uid://v6sckr0m5gkp"
ResourceManager="*uid://qcnojtaw58rn"
UuidGenerator="*uid://b2kic866u0xqp"
ArmorSheets="*uid://c5gfqrh41exrg"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[dotnet]

project/assembly_name="Celestial Builder"

[input_devices]

pointing/emulate_mouse_from_touch=false

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
